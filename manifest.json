{
  "manifest_version": 3,
  "name": "Claude Usage",
  "version": "1.0.0",
  "description": "Shows your Claude usage (5 h session, week, credit budget) from your claude.ai session.",
  "action": {
    "default_popup": "popup.html",
    "default_title": "Claude Usage",
    "default_icon": {
      "16": "icons/icon16.png",
      "32": "icons/icon32.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },
  "icons": {
    "16": "icons/icon16.png",
    "32": "icons/icon32.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "permissions": ["storage", "alarms"],
  "host_permissions": ["https://claude.ai/*"],
  "background": {
    "service_worker": "background.js",
    "type": "module"
  }
}
